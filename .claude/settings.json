{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$p = ($input | ConvertFrom-Json).tool_input.file_path; if ($p -like '*\\src\\main\\*') { & 'C:\\Users\\xjann\\Desktop\\MinecraftServer\\deploy.ps1' }",
            "shell": "powershell",
            "timeout": 120,
            "statusMessage": "Building & deploying Utility plugin..."
          }
        ]
      }
    ]
  }
}
